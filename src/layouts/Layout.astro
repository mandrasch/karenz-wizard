---
// Karenz Wizard root layout.
// - One root structure: <header> -> <main id="main"> -> <footer>
// - data-layout="home|subpages" on <main>
// - Skip link first in tab order, lands on <main>
// - German-only (lang="de-AT"), umami analytics inline in <head>
// - SEO title/description from ~/utils/seo.ts, overridable via metadata prop
import '~/assets/styles/tailwind.css';
import '~/assets/styles/kw.css';
import '@fontsource-variable/inter';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';

import HeaderKW from '~/components/widgets/HeaderKW.astro';
import FooterKW from '~/components/widgets/FooterKW.astro';
import { getSeoMeta } from '~/utils/seo';

// Default og:image lives in public/ (stable URL for social-platform caches).
// See discussion: hashed /_astro/ URLs break historical social previews when the hash changes.
const OG_IMAGE_DEFAULT = '/karenz-wizard-og.jpg';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const pathname = Astro.url.pathname;
const seo = getSeoMeta(pathname);

const pageTitle = metadata.title ?? seo.title;
const pageDescription = metadata.description ?? seo.description;

// Canonical + absolute og:image URL. Astro.site is set in astro.config.ts.
const canonicalUrl = new URL(pathname, Astro.site).toString();
const ogImagePath = seo.image ?? OG_IMAGE_DEFAULT;
const ogImageUrl = new URL(ogImagePath, Astro.site).toString();

const layoutVariant = pathname === '/' ? 'home' : 'subpages';
---

<!doctype html>
<html lang="de-AT">
  <head>
    <CommonMeta />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Karenz Wizard" />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <Favicons />
    <SiteVerification />

    <!-- umami analytics (preserved from pre-migration app.html) -->
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="ad87adb8-6ab0-406a-a478-ba5c64683193"></script>

    <!-- AstroWind font + color tokens (ported from the deleted CustomStyles.astro,
         d56c54d:src/components/CustomStyles.astro).
         These are the CSS vars that tailwind.config.js references for font-sans/
         font-serif/font-heading and that tailwind.css `@layer utilities` references
         for .bg-page, .text-default, .text-muted, .text-heading. -->
    <style is:inline>
      :root {
        --aw-font-sans: 'Inter Variable';
        --aw-font-serif: 'Inter Variable';
        --aw-font-heading: 'Inter Variable';

        --aw-color-primary: rgb(1 97 239);
        --aw-color-secondary: rgb(1 84 207);
        --aw-color-accent: rgb(109 40 217);

        --aw-color-text-heading: rgb(0 0 0);
        --aw-color-text-default: rgb(16 16 16);
        --aw-color-text-muted: rgb(16 16 16 / 66%);
        --aw-color-text-page: rgb(16 16 16);
        --aw-color-bg-page: rgb(255 255 255);
        --aw-color-bg-page-dark: rgb(3 6 32);
      }
    </style>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <a class="skip-link" href="#main">Zum Inhalt springen</a>

    <HeaderKW />

    <main id="main" tabindex="-1" data-layout={layoutVariant}>
      <div class="page-grid">
        <slot />
      </div>
    </main>

    <FooterKW />
  </body>
</html>
