---
// Karenz Wizard root layout.
// - One root structure: <header> -> <main id="main"> -> <footer>
// - data-layout="home|subpages" on <main>
// - Skip link first in tab order, lands on <main>
// - German-only (lang="de-AT"), umami analytics inline in <head>
// - SEO title/description from ~/utils/seo.ts, overridable via metadata prop
import '~/assets/styles/tailwind.css';
import '~/assets/styles/kw.css';
import '@fontsource/ibm-plex-sans-condensed';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';

import HeaderKW from '~/components/widgets/HeaderKW.astro';
import FooterKW from '~/components/widgets/FooterKW.astro';
import { getSeoMeta } from '~/utils/seo';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const pathname = Astro.url.pathname;
const seo = getSeoMeta(pathname);

const pageTitle = metadata.title ?? seo.title;
const pageDescription = metadata.description ?? seo.description;

const layoutVariant = pathname === '/' ? 'home' : 'subpages';
---

<!doctype html>
<html lang="de-AT">
  <head>
    <CommonMeta />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <Favicons />
    <SiteVerification />

    <!-- umami analytics (preserved from pre-migration app.html) -->
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="ad87adb8-6ab0-406a-a478-ba5c64683193"></script>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <a class="skip-link" href="#main">Zum Inhalt springen</a>

    <HeaderKW />

    <main id="main" tabindex="-1" data-layout={layoutVariant}>
      <div class="page-grid">
        <slot />
      </div>
    </main>

    <FooterKW />
  </body>
</html>
