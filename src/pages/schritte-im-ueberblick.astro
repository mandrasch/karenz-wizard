---
// /schritte-im-ueberblick/ — "Die Schritte im Überblick"
// Linear vertical stack of numbered step cards (Option C from the
// CTA streamlining discussion). Top-level steps 1–4, with 3.1 / 3.2
// indented under step 3 to preserve the parent/variant relationship.
//
// SEO title comes from seo.ts via pathname lookup.
import Layout from '~/layouts/Layout.astro';
import PrivacyEmbed from '~/components/blog/PrivacyEmbed.astro';

type StepCta = {
  label: string;
  href: string;
};

type StepEmbed = {
  provider: 'youtube' | 'twitter' | 'mastodon' | 'vimeo' | 'other';
  embedUrl: string;
  title: string;
  directUrl: string;
};

type Step = {
  number: string; // "1", "2", "3", "3.1", "3.2", "4"
  kicker?: string; // e.g. "Schritt 1" — displayed above title
  title: string;
  description: string[];
  cta: StepCta;
  variant?: 'primary' | 'sub'; // 'sub' = indented sub-step (3.1/3.2)
  embed?: StepEmbed;
};

const steps: Step[] = [
  {
    number: '1',
    kicker: 'Schritt 1',
    title: 'Der (Papa-)Monat nach Geburt steht dir immer zu',
    description: [
      'Die gute Nachricht: Du hast in Österreich - großartigerweise! -  das Recht auf (unbezahlte) Freistellung im ersten Monat nach der Geburt. So kannst du den ersten Monat daheim verbringen und im Wochenbett voll unterstützen.',
      'Tipp: Die Papamonat-Freistellung gilt erst ab Entlassung von Mutter und Kind aus dem Krankenhaus, heb dir also ein paar Urlaubstage für die Krankenhauszeit noch auf.',
      'Die "schlechte" Nachricht: Anspruch auf die staatliche Förderung, den Familienzeitbonus für diesen Monat, hast du allerdings nicht automatisch — das ist an die 182-Tage-Regel geknüpft:',
    ],
    cta: { label: 'Familienzeitbonus-Anspruch prüfen', href: '/fzb-anspruch/' },
    embed: {
      provider: 'youtube',
      embedUrl: 'https://www.youtube-nocookie.com/embed/IMUBAZGAER8',
      title: 'Papamonat in Österreich | Meldung, Antrag & Geld (AK/YouTube)',
      directUrl: 'https://www.youtube.com/watch?v=IMUBAZGAER8',
    },
  },
  {
    number: '2',
    kicker: 'Schritt 2: Die finanzielle Basis',
    title: 'Welchen Kinderbetreuungsgeld-Anspruch habt ihr?',
    description: [
      'Bevor ihr in die Detailplanung geht, müsst ihr das finanzielle Fundament klären. Hat mindestens einer von euch Anspruch auf das einkommensabhängige Kinderbetreuungsgeld (eaKBG)?',
      'Der Check: Erfüllt mindestens einer oder ihr beide die 182-Tage-Regel (durchgehende Beschäftigung vor der Geburt)? Hat nur einer Anspruch, bekommt der andere in seiner Karenzzeit Sonderleistung 1. Falls gar kein Anspruch auf das eaKBG besteht, gibt es das pauschale Modell.',
    ],
    cta: { label: 'eaKBG-Anspruch jetzt prüfen', href: '/eakbg-anspruch/' },
  },
  {
    number: '3',
    kicker: 'Schritt 3: Die Zeit und Aufteilung',
    title: 'Wie lange wollt ihr zu Hause bleiben? Wie wollt ihr es aufteilen?',
    description: [
      'Geld und Recht sind zwei verschiedene Paar Schuhe. In Österreich habt ihr gegenüber dem Arbeitgeber meist Anspruch auf zwei Jahre Karenz, auch wenn das gute Geld (eaKBG, 80% vom Einkommen) nur maximal 14 Monate lang fließt.',
      'Nutzt unser Planungstool, um die Monate zwischen euch aufzuteilen - falls einer von euch Anspruch auf eaKBG hat:',
    ],
    cta: { label: 'Eure eaKBG-Karenz interaktiv planen', href: '/eakbg-planer/' },
  },
  {
    number: '3.1',
    kicker: 'Option zu Schritt 3',
    title: 'Unbezahlte Karenz: Länger daheim bleiben',
    description: [
      'Eine unbezahlte Karenz ist ebenso möglich um die Karenz zu verlängern, bis zum 2. Lebensjahr des Kindes habt ihr ja rechtlichen Anspruch auf Karenz (= unbezahlte Freistellung). Den Lebensunterhalt müsst ihr dann natürlich aus Ersparnissen oder über das Einkommen des/der Partner/in finanzieren in diesen Monaten.',
    ],
    cta: { label: 'Alles zur unbezahlten Karenz', href: '/unbezahlte-karenz/' },
    variant: 'sub',
  },
  {
    number: '3.2',
    kicker: 'Option zu Schritt 3',
    title: 'Das 20h/20h-Modell: Gemeinsam anpacken mit Eltern-Teilzeit',
    description: [
      'Echte Partnerschaft und Equal Care kann man auch so gestalten, dass beide Elternteile früh wieder in den Job einsteigen — aber mit reduzierter Stundenanzahl. Dieses Modell wird leider auch in Medienberichten rund um die Aufteilung der Karenz oft nicht beleuchtet, denn auch hier können Väter echte Verantwortung tragen.',
      'Im 20h/20h-Modell wechselt ihr euch beispielsweise mittags ab: Die Mutter arbeitet von 8 bis 12 Uhr, der Vater von 13 bis 17 Uhr.',
      'Gut zu wissen: Falls ihr Anspruch habt, seid ihr vor Kündigung geschützt.',
      'Die schlechte Nachricht: Eltern-Teilzeit ist an bestimmte Vorraussetzungen geknüpft.',
      'Erfahrt hier, ob ihr in Eltern-Teilzeit gehen könnt:'
    ],
    cta: { label: 'Mehr über Eltern-Teilzeit erfahren', href: '/elternteilzeit-20-20/' },
    embed: {
      provider: 'youtube',
      embedUrl: 'https://www.youtube-nocookie.com/embed/sepdrZagF98',
      title: 'Elternteilzeit in Österreich (AK/YouTube)',
      directUrl: 'https://www.youtube.com/watch?v=sepdrZagF98',
    },
    variant: 'sub',
  },
  {
    number: '4',
    kicker: 'Schritt 4: Die (eigentlich) große Entscheidung',
    title: 'Ab wann in Fremdbetreuung?',
    description: [
      'Wann ist der richtige Zeitpunkt für den Kindergarten oder eine Tagesmutter/Tagesvater-Gruppe? Das ist eine sehr emotionale Frage und zudem in jedem Bundesland völlig unterschiedlich geregelt - beispielsweise ab welchem Alter Kinder überhaupt aufgenommen werden. Zudem beginnt die Kindergarten-Saison in Wien beispielsweise regulär im Herbst, es gibt also auch zeitliche Fristen zu beachten.',
      'Von dieser Frage hängt natürlich aber ab, wie viel Stunde ihr jeweils arbeiten könnt und wie lang ihr die Karenz (oder Modelle wie Eltern-Teilzeit) plant.',
      'Ich habe ein paar Links gesammelt, die Entscheidung trefft ihr jedoch ganz allein - und jedes Kind ist individuell und anders entwickelt:',
    ],
    cta: { label: 'Links zur Frage der Fremdbetreuung', href: '/faq/#empfohlene-fremdbetreuung/' },
  },
];
---

<Layout>
  <section class="content">
    <header class="mx-auto mt-10 max-w-3xl space-y-3 text-center">
      <h1 class="font-heading text-3xl font-bold leading-tight tracking-tight text-slate-900 sm:text-4xl">
        Die Schritte im Überblick
      </h1>
      <p class="text-base leading-relaxed text-slate-600">
        Diese Seite ist <strong>„Hilfe zur Selbsthilfe"</strong>. Spielt hier unverbindlich
        verschiedene Szenarien durch und bekommt ein Gefühl für eure Möglichkeiten, bevor ihr die
        offiziellen Schritte angeht.
      </p>
    </header>

    <ol class="mx-auto mt-10 max-w-3xl list-none space-y-6 p-0" aria-label="Planungsschritte">
      {
        steps.map((step) => (
          <li class={step.variant === 'sub' ? 'ml-6 sm:ml-12' : ''}>
            <article
              class={
                'flex flex-col gap-4 overflow-hidden rounded-3xl border bg-white px-6 py-6 shadow-sm transition-shadow duration-200 focus-within:shadow-lg hover:shadow-lg sm:px-8 sm:py-7 ' +
                (step.variant === 'sub'
                  ? 'border-slate-200/80'
                  : 'border-slate-200/60')
              }
            >
              <div class="flex items-start gap-4">
                <span
                  class={
                    // items-start on the row + leading-none on the numeral means
                    // its top edge aligns with the top of the kicker, instead of
                    // baseline-matching a huge number to a tiny kicker (which
                    // visually lifted the numeral ~20px above the label).
                    'shrink-0 font-heading font-bold leading-none tabular-nums ' +
                    (step.variant === 'sub'
                      ? 'text-xl text-slate-400'
                      : 'text-3xl text-[#C94D54] sm:text-4xl')
                  }
                  aria-hidden="true"
                >
                  {step.number}
                </span>
                <div class="flex-1">
                  {step.kicker && (
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                      {step.kicker}
                    </p>
                  )}
                  <h2
                    class={
                      'mt-1 font-heading font-bold leading-tight text-slate-900 ' +
                      (step.variant === 'sub' ? 'text-lg sm:text-xl' : 'text-xl sm:text-2xl')
                    }
                  >
                    {step.title}
                  </h2>
                </div>
              </div>

              <div class="space-y-3">
                {step.description.map((paragraph) => (
                  <p class="text-sm leading-relaxed text-slate-600 sm:text-base">{paragraph}</p>
                ))}
              </div>

              <div>
                <a
                  href={step.cta.href}
                  class={
                    'inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition sm:text-base ' +
                    (step.variant === 'sub'
                      ? 'border border-[#C94D54] text-[#C94D54] hover:bg-[#C94D54]/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C94D54]'
                      : 'bg-[#C94D54] text-white hover:bg-[#b64048] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C94D54]')
                  }
                >
                  {step.cta.label}
                  <span aria-hidden="true">→</span>
                </a>
              </div>

              {step.embed && (
                <PrivacyEmbed
                  provider={step.embed.provider}
                  embedUrl={step.embed.embedUrl}
                  title={step.embed.title}
                  directUrl={step.embed.directUrl}
                />
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
