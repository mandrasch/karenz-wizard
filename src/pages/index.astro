---
// Home page. Streamlined hero with one primary CTA to /schritte-im-ueberblick/
// (the "Die Schritte im Überblick" page, which holds the numbered
// step cards that used to live in this hero section).
// Blog latest-posts section below stays.
import Layout from '~/layouts/Layout.astro';
import PostCard from '~/components/blog/PostCard.astro';
import PostGrid from '~/components/blog/PostGrid.astro';
import { getCollection } from 'astro:content';
import { toTeaser } from '~/utils/teaser';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 9)
  .map((post) => ({
    title: post.data.title,
    slug: post.data.slug,
    pubDate: post.data.pubDate,
    teaser: toTeaser(post.body ?? ''),
  }));
---

<Layout>
  <section class="full-bleed">
    <div class="relative w-full bg-white text-slate-900">
      <div class="content px-6 pt-12 sm:pt-12">
        <div class="mx-auto flex max-w-5xl flex-col gap-12">
          <div class="flex h-56 items-center justify-center sm:h-64 lg:h-72 xl:h-80">
            <img
              src="/hero_karenz_wizard.jpg"
              alt="Illustration eines Zauberers, der Eltern beim Planen unterstützt"
              class="h-full max-h-full w-auto max-w-full rounded-2xl border border-slate-200 object-contain"
            />
          </div>

          <div class="mx-auto w-full max-w-3xl space-y-6 px-6 pb-2 text-slate-600">
            <h1 class="text-center text-3xl leading-snug font-bold text-slate-900 sm:text-4xl">
              Euch brummt der Kopf von der Karenzplanung?
            </h1>
            <p class="text-base leading-relaxed text-slate-600">
              Zwei Jahre Recht auf Karenz, aber nur maximal 14 Monate Förderung durch das eaKBG?
              Immer wieder berichten die Medien, wie arg wenig Väter in Österreich in Karenz gehen.
              Aber wie teilt man sich denn die ersten Jahre mit Baby so auf, dass es für beide
              wirklich fair ist? Welche Möglichkeiten gibt es?
            </p>
            <p class="text-base leading-relaxed text-slate-600">
              Als werdender Vater stand ich vor genau diesem Berg an Fragen – und habe kaum
              durchgeblickt. Deshalb habe ich diese Webseite als Hobby-Projekt gestartet, um mehr
              Väterkarenz zu ermöglichen. Denn ein guter Überblick ist zumindest der erste Schritt.
            </p>

            <div class="flex justify-center pt-2">
              <a
                href="/schritte-im-ueberblick/"
                class="inline-flex items-center justify-center gap-2 rounded-full bg-[#C94D54] px-7 py-4 text-base font-semibold text-white transition hover:bg-[#b64048] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C94D54]"
              >
                Die Schritte im Überblick
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    latestPosts.length > 0 && (
      <section class="content">
        <div class="space-y-8">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold tracking-wide text-slate-500 uppercase">Blog</p>
            <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Aktuelle Beiträge</h2>
          </div>

          <PostGrid>
            {latestPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </PostGrid>

          <div class="text-center">
            <a
              class="inline-flex items-center justify-center rounded-full border border-[#C94D54] px-6 py-3.5 text-base font-semibold text-[#C94D54] transition hover:bg-[#C94D54]/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C94D54]"
              href="/blog/"
            >
              Alle Beiträge anzeigen
            </a>
          </div>
        </div>
      </section>
    )
  }
</Layout>
