---
// Ported from src/routes/reaktionen-und-feedback/+page.svelte (pre-migration tag).
// SEO title/description come from ~/utils/seo.ts via pathname lookup.
import Layout from '~/layouts/Layout.astro';
import ContentPage from '~/components/widgets/ContentPage.astro';
---

<Layout>
  <ContentPage
    title="Reaktionen und Feedback"
    subtitle="Ein Blick darauf, wie Eltern ihre Erfahrungen mit unterschiedlichen Familienzeitmodellen beschreiben."
  >
      <blockquote>
        Ich finde die visuelle Darstellung des eaKBG Planers super. Das hätte mir vor Kurzem einigen
        Stunden an Recherche erspart. (<a href="https://www.instagram.com/reel/DR9RaZTDnXO/"
          >Instagram-Kommentar</a
        >)
      </blockquote>

      <blockquote>
        Danke für ihre Arbeit. Sehr coole Seite! 🙌 (<a
          href="https://www.instagram.com/reel/DR9RaZTDnXO/">Instagram-Kommentar</a
        >)
      </blockquote>

      <blockquote
        class="not-prose rounded-lg border border-slate-200 bg-slate-50 p-6 text-base text-slate-800"
      >
        <p>
          "Das ist in Deutschland sehr ähnlich, Kindergeld geht nach Einkommen und ist gedeckelt.
          Ich würde gerne mehr als zwei Monate (von 14) machen, 50/50 oder noch mehr, aber das ist
          finanziell einfach nicht drin. Vielleicht wäre Kindergeld nach Haushaltseinkommen oder
          sogar pauschal ein besseres Modell?"
        </p>
        <footer class="mt-4 text-sm text-slate-500">
          Quelle:
          <a
            href="https://mastodon.social/@PapaVonK1/114993215091739234"
            class="inline-flex items-center gap-1 text-slate-600 underline decoration-slate-400 underline-offset-4 hover:text-slate-900 hover:decoration-slate-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-500"
            rel="noopener noreferrer"
            target="_blank"
          >
            @PapaVonK1 auf Mastodon
          </a>
        </footer>
      </blockquote>
  </ContentPage>
</Layout>
