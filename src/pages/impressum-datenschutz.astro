---
// Ported from src/routes/impressum-datenschutz/+page.svelte.
// SEO from ~/utils/seo.ts via pathname.
import Layout from '~/layouts/Layout.astro';
---

<Layout>
  <section class="content">
    <header class="mt-10">
      <h1 class="text-3xl font-semibold text-slate-900">Datenschutz</h1>
    </header>

    <div class="prose mt-6">
      <div class="mx-auto max-w-4xl px-4 py-8">
        <p class="mb-4 text-gray-700">
          Dieses Projekt speichert oder verarbeitet keine personenbezogenen Daten.
        </p>

        <p class="mb-4 text-gray-700">
          Alle Daten, die eingegeben werden, werden ausschließlich lokal im Browser mittels
          JavaScript verarbeitet. Es erfolgt keine Speicherung, Weitergabe o.ä.
        </p>

        <p class="mb-4 text-gray-700">
          Die reinen Webseiten-Aufrufe (Views) zähle ich mit dem datentschutzfreundlichen Tool <a
            href="https://umami.is/">umami</a
          >, welches ebenfalls keine personenbezogenen Daten speichert oder verarbeitet - und auch
          keinerlei Cookies nutzt.
        </p>

        <p class="mb-8 text-gray-700">
          🌱 Gehostet beim nachhaltigen Anbieter
          <a
            href="https://www.manitu.de/"
            class="text-blue-600 underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Manitu
          </a>, offiziell gelistet im
          <a
            href="https://www.thegreenwebfoundation.org/directory/"
            class="text-blue-600 underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Green Hosting Directory
          </a>.
        </p>

        <h2 class="mb-4 text-2xl font-semibold">Impressum</h2>
        <p class="mb-4 text-gray-700">
          Ein privates Hobby-Projekt von <a
            href="https://mandrasch.dev"
            class="text-blue-600 underline-offset-2 hover:underline">Matthias Andrasch</a
          >.
        </p>
        <p class="mb-8 text-gray-700">
          Kontaktdaten und vollständiges Impressum findest du unter:
          <a
            href="https://matthias-andrasch.eu/blog/impressum-datenschutz/"
            class="text-blue-600 underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Impressum & Datenschutz
          </a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
