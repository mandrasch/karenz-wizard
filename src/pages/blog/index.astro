---
// Blog list page. Ported from src/routes/blog/+page.svelte.
// Sorted by pubDate descending. Teaser from body via toTeaser().
import Layout from '~/layouts/Layout.astro';
import Disclaimer from '~/components/widgets/Disclaimer.astro';
import PostCard from '~/components/blog/PostCard.astro';
import PostGrid from '~/components/blog/PostGrid.astro';
import { getCollection } from 'astro:content';
import { toTeaser } from '~/utils/teaser';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => ({
    title: post.data.title,
    slug: post.data.slug,
    pubDate: post.data.pubDate,
    teaser: toTeaser(post.body ?? ''),
  }));
---

<Layout>
  <section class="content">
    <header class="mt-10 space-y-4 text-center">
      <h1 class="text-3xl font-semibold text-slate-900">Blog</h1>
      <p class="text-base leading-relaxed text-slate-600">
        Aktuelle Infos zu dieser Webseite sowie ausgewählte Links rund um Kinderbetreuungsgeld und
        Karenzplanung.
      </p>
    </header>

    <div class="mx-auto max-w-3xl">
      <Disclaimer />
    </div>

    <div class="mt-10">
      {
        posts.length === 0 ? (
          <p class="rounded-3xl border border-dashed border-slate-300/80 bg-slate-50 px-6 py-10 text-base text-slate-600">
            Noch gibt es keine veröffentlichten Beiträge. Schau bald wieder vorbei.
          </p>
        ) : (
          <PostGrid>
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </PostGrid>
        )
      }
    </div>
  </section>
</Layout>
