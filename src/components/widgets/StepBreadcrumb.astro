---
type Props = {
  number: string;
  total?: number;
};

const { number, total = 9 } = Astro.props;
---

<nav class="text-sm text-slate-500" aria-label="Breadcrumb">
  <a
    href="/schritte-im-ueberblick/"
    class="hover:text-slate-700 hover:underline underline-offset-4"
  >
    Schritte
  </a>
  <span class="mx-2 text-slate-400" aria-hidden="true">›</span>
  <span>Schritt {number} von {total}</span>
</nav>
